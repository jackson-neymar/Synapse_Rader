# ============================================================
# Synapse_Rader 环境变量配置
# 复制此文件为 .env 并填入真实值
# ============================================================

# DeepSeek LLM（必需 — 核心分析引擎）
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Embedding 模型配置（默认本地模型，国内可用）
EMBEDDING_BACKEND=local
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
# 如果下载到本地路径，改为：/home/czh/models/bge-large-zh-v1.5
EMBEDDING_DEVICE=cpu
# 如果用 OpenAI Embedding（需科学上网），改为下面配置：
# EMBEDDING_BACKEND=openai
# EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=sk-your-openai-key

# GitHub Token（强烈建议，提升 API 限流）
GITHUB_TOKEN=

# 飞书应用（推送日报用，可后配）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CHAT_ID=

# 数据库（默认 SQLite，无需改动）
# DATABASE_URL=sqlite+aiosqlite:///./data/synapse_rader.db
# CHROMA_PERSIST_PATH=./data/chroma

# 定时任务（Cron 表达式）
# CRON_COLLECT=0 7 * * *
# CRON_DISPATCH=0 8 * * *

# 限制参数
# LLM_RATE_LIMIT_RPM=30
# ANALYSIS_TIMEOUT_SECONDS=60
